# --- Segreti (MAI committare) ---
# Le chiavi API Alpaca NON stanno in file: sono variabili (secret) delle singole routine.
secrets/
*.key
*recovery*
*.env
*alpaca_keys*

# --- Stato runtime ---
# I JSON di stato SONO tracciati e pushati (backup/audit, vedi lib/gitsync.py).
# Si ignorano solo i log di processo del loop di esecuzione (Routine 04).
state/*.out
state/*.err

# --- Python ---
__pycache__/
*.pyc

# --- Sistema / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# Mantieni le cartelle di stato vuote nel repo
!state/.gitkeep
!state/archive/.gitkeep
